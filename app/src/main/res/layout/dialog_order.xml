<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- DARK HEADER -->
    <LinearLayout
        android:orientation="vertical"
        android:background="#2C1810"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/dialogLabel"
            android:text="COMMANDER"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:textColor="#D4883A"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/dialogMenuName"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#F5E6C8"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/dialogMenuPrice"
            android:textSize="14sp"
            android:textColor="#8B7355"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- BODY -->
    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Quantité"
            android:textSize="13sp"
            android:textColor="#8B7355"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- QUANTITY STEPPER -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDecrement"
                android:text="−"
                android:textSize="20sp"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:textColor="#1C1108"
                app:backgroundTint="#F0E8D8"
                app:cornerRadius="12dp"/>

            <TextView
                android:id="@+id/txtQuantity"
                android:text="1"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1C1108"
                android:gravity="center"
                android:minWidth="64dp"
                android:layout_width="wrap_content"
                android:layout_height="48dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIncrement"
                android:text="+"
                android:textSize="20sp"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:textColor="#1C1108"
                app:backgroundTint="#F0E8D8"
                app:cornerRadius="12dp"/>

        </LinearLayout>

        <!-- DIVIDER -->
        <View
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0E8D8"/>

        <!-- TOTAL -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Total"
                android:textSize="14sp"
                android:textColor="#8B7355"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtTotal"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#D4883A"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>